rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Sellers
    match /sellers/{sellerId} {
      allow read: if true;
      allow write: if isOwner(sellerId);
      
      match /private/contact {
        allow read: if isAuthenticated();
        allow write: if isOwner(sellerId);
      }
    }

    // Users — profile readable by any authenticated user, writable by owner only
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      match /saved/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Items
    match /items/{itemId} {
      allow read: if true;
      
      allow create: if isAuthenticated() &&
                    request.resource.data.price >= 50 &&
                    request.resource.data.price <= 25000 &&
                    request.resource.data.images.size() <= 5 &&
                    request.resource.data.images.size() >= 1 &&
                    request.resource.data.seller_id == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    (isOwner(resource.data.seller_id) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['swipe_count']) &&
                     request.resource.data.swipe_count == resource.data.swipe_count + 1));
                    
      allow delete: if isOwner(resource.data.seller_id);
    }

    // Conversations — participants only
    match /conversations/{conversationId} {
      // Create: caller must be in the new doc's participants list
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.participants;
      // Read/update/delete: caller must be in the existing doc's participants list
      allow read, update, delete: if isAuthenticated() &&
                                  request.auth.uid in resource.data.participants;
    }
    
    // Messages subcollection
    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // Audit Events — write-only per user
    match /events/{eventId} {
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Rate limits — Cloud Functions only; clients cannot write
    match /_rate_limits/{document=**} {
      allow read, write: if false;
    }
  }
}
