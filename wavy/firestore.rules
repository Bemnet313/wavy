rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth requirements helper
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Sellers
    match /sellers/{sellerId} {
      allow read: if true; // Public profiles
      allow write: if isOwner(sellerId);
      
      // Protected seller data (Task 1: Phone reveal)
      match /private/contact {
        allow read: if isAuthenticated(); // Require login to view phone
        allow write: if isOwner(sellerId);
      }
    }

    // Items (Task 2: Limits)
    match /items/{itemId} {
      allow read: if true; // Public feed
      
      // Enforce 50 - 25k ETB & Max 5 images
      allow create: if isAuthenticated() &&
                    request.resource.data.price >= 50 &&
                    request.resource.data.price <= 25000 &&
                    request.resource.data.images.size() <= 5 &&
                    request.resource.data.images.size() >= 1 &&
                    request.resource.data.seller_id == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    (isOwner(resource.data.seller_id) || 
                    request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['swipe_count', 'interest_count', 'status'])); // allow interaction updates
                    
      allow delete: if isOwner(resource.data.seller_id);
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && 
                         (request.auth.uid in resource.data.participants || 
                          request.auth.uid in request.resource.data.participants);
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Audit Events
    match /events/{eventId} {
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if false; // Write only for clients
    }
  }
}
