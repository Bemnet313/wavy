{
    "firestore": {
        "rules": "wavy/firestore.rules",
        "indexes": "wavy/firestore.indexes.json"
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log"
            ]
        }
    ],
    "storage": {
        "rules": "wavy/storage.rules"
    }
}